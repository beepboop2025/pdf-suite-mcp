{
  "name": "pdf-suite-mcp",
  "version": "2.1.0",
  "description": "Comprehensive MCP server for PDF operations — 37 tools for reading, creating, merging, splitting, watermarking, stamping, form filling, redacting, searching, comparing, and more. Built on pdf-lib and unpdf. No cloud, no API key.",
  "type": "module",
  "bin": {
    "pdf-toolkit-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "unpdf": "^1.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beepboop2025/pdf-toolkit-mcp.git"
  },
  "homepage": "https://github.com/beepboop2025/pdf-toolkit-mcp#readme",
  "bugs": {
    "url": "https://github.com/beepboop2025/pdf-toolkit-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pdf",
    "pdf-lib",
    "unpdf",
    "pdf-tools",
    "merge-pdf",
    "split-pdf",
    "pdf-forms",
    "redact",
    "watermark"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "banner.svg"
  ]
}
